# Docker --env-file 용 placeholder. 실 사용 시 `.env` 로 복사 (gitignore 대상).
# 결정 근거: docs/adr/0011-multistage-docker-build-strategy.md

# Profile (local | prod)
SPRING_PROFILES_ACTIVE=local

# DB (prod profile 사용 시 필수 — local 은 H2 in-memory 자동)
DB_URL=jdbc:mysql://host.docker.internal:3306/profile
DB_USERNAME=replace-me
DB_PASSWORD=replace-me

# S3 (prod profile 필수)
S3_BUCKET=replace-me
S3_REGION=ap-northeast-2

# S3 자격증명 — 미설정 시 DefaultCredentialsProvider fallback (ADR-0004)
# 컨테이너 안에서는 IAM Role / 컨테이너 메타데이터 사용 권장. 로컬 개발 시에만 채움.
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
